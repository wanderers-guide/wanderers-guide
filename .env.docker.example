# Public URL the browser uses to reach kong (the API gateway).
# Localhost: http://localhost:8000. Production: https://api.your-domain.com
PUBLIC_SUPABASE_URL=http://localhost:8000

# JWT secret used to sign ANON_KEY/SERVICE_ROLE_KEY (32+ chars).
# Generate with: openssl rand -hex 32
JWT_SECRET=replace-me-with-a-32-char-random-secret

# JWTs derived from JWT_SECRET. Generate at:
# https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
ANON_KEY=eyJ...
SERVICE_ROLE_KEY=eyJ...

# Postgres
POSTGRES_PASSWORD=replace-me-with-a-strong-password
POSTGRES_PORT=54322

# Frontend
FRONTEND_PORT=3000
SITE_URL=http://localhost:3000
ADDITIONAL_REDIRECT_URLS=
VITE_ENV=production

# Auth
JWT_EXPIRY=3600
EMAIL_AUTOCONFIRM=true

# Studio (opt-in via `docker compose --profile studio up`)
STUDIO_PORT=54323
DEFAULT_ORG_NAME=Default
DEFAULT_PROJECT_NAME=Wanderer's Guide
