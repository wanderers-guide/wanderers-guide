# Public URL the browser uses to reach kong (the API gateway).
PUBLIC_SUPABASE_URL=http://localhost:8000

# JWT secret used to sign ANON_KEY/SERVICE_ROLE_KEY (32+ chars).
# The defaults below are a matched set that works out-of-the-box for local
# Docker dev. **DO NOT use these on any publicly reachable host**
# For deploys, generate fresh values:
#   JWT_SECRET via:  openssl rand -hex 32
#   ANON_KEY/SERVICE_ROLE_KEY via:
#     https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
JWT_SECRET=tpTsNWDCSUHgYXKDLmg9xD8aUoUl2jSAnIA1I4Ox
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlIiwiaWF0IjoxNzc3NzgwODAwLCJleHAiOjE5MzU1NDcyMDB9.vp6J2oNVQgHMzZG6B6iuTTb_gFPD7jzTyVoxiw0nhf0
