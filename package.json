{
  "name": "wanderers-guide",
  "private": true,
  "scripts": {
    "docker:start": "docker compose up -d",
    "docker:stop": "docker compose down",
    "docker:rebuild": "docker compose up -d --build frontend",
    "docker:reset": "docker compose down -v && docker compose up -d --wait && ./data/create-db-docker.sh && ./data/seed-test-user.sh",
    "docs:dev": "npm --prefix docs run dev",
    "docs:build": "npm --prefix docs run build",
    "docs:check": "npm --prefix docs run broken-links",
    "test:api": "cd supabase && deno test --allow-net --allow-env --allow-read functions/_tests/"
  }
}
