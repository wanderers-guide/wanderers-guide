# The dependency tree targets React 19, but a few deps (e.g. framer-motion@10)
# still declare a React 18 peer range even though they work with React 19.
# Bun installs fine (it's lenient about peer conflicts); this makes npm behave
# the same way so `npm install` doesn't abort with ERESOLVE during the build.
legacy-peer-deps=true
